msgid "Теперь при покупке iPhone в iHome дарим фирменный картхолдер 📱"
msgstr "Perkant iPhone iHome dovanojame firminį kortelių dėklą 📱"

msgid "Стильный. Удобный."
msgstr "Stilingas. Patogus."

msgid "Просто прикрепили к телефону: карта, пропуск или права всегда под рукой."
msgstr "Tiesiog pritvirtink prie telefono: kortelė, leidimas ar teisės visada po ranka."

msgid "Важно: количество ограничено."
msgstr "Svarbu: kiekis ribotas."

msgid "И, как показывает практика, такие вещи улетают очень быстро."
msgstr "Ir praktika rodo, kad tokie daiktai dingsta labai greitai."

msgid "Успевайте забрать iPhone по приятной цене и получить бонус, который действительно будете использовать каждый день"
msgstr "Spėkite įsigyti iPhone už gerą kainą ir gauti bonusą, kurį naudosite kasdien"

msgid "Ждем вас в iHome ежедневно с 10:00 до 20:00"
msgstr "Laukiame jūsų iHome kasdien nuo 10:00 iki 20:00"

msgid "г. Обнинск, пр-кт Ленина, д.137 к3, 2-ой этаж (БЦ Циолковский)"
msgstr "Obninskas, Lenino pr. 137 k3, 2 aukštas (BC Ciolkovskij)"

msgid "Мир технологий ближе чем вы думаете!"
msgstr "Technologijų pasaulis arčiau nei manote!"

msgid "Не знаете, что подарить? Дарите выбор"
msgstr "Nežinote, ką padovanoti? Dovanokite pasirinkimą"

msgid "Подарочные сертификаты iHome — это простой способ угадать с подарком без лишних сомнений"
msgstr "iHome dovanų kuponai – paprastas būdas neprašauti su dovana"

msgid "iPhone, AirPods или Apple Watch пусть выбирают сами"
msgstr "iPhone, AirPods ar Apple Watch – tegul pasirenka patys"

msgid "Универсально"
msgstr "Universalus"

msgid "Удобно"
msgstr "Patogu"

msgid "Всегда в точку"
msgstr "Visada tiksliai"

msgid "Подарите эмоции и свободу выбора"
msgstr "Padovanokite emocijas ir pasirinkimo laisvę"

msgid "За сертификатами ждем вас в iHome!"
msgstr "Laukiame jūsų iHome dėl dovanų kuponų!"

